<Window x:Class="Manager_password.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Manager_password"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TextBox x:Name="PassPrifile" HorizontalAlignment="Left" Height="23" Margin="355,225,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
        <ComboBox Name="nameProfile"  HorizontalAlignment="Left" Margin="355,165,0,0" VerticalAlignment="Top" Width="120"/>
        <Button x:Name="EnterPrifile" Content="Button" HorizontalAlignment="Left" Margin="390,285,0,0" VerticalAlignment="Top" Width="75"/>
        <Button Name="AddProfile" Content="Button" HorizontalAlignment="Left" Margin="660,30,0,0" VerticalAlignment="Top" Width="75" Click="AddProfile_Click"/>

    </Grid>
</Window>
