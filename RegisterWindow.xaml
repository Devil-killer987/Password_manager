<Window x:Class="Password_manager.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Password_manager"
        mc:Ignorable="d"
         Title="Менеджер паролей - Регистрация" 
        Height="600" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown">
    <Border CornerRadius="20" Background="White" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3" Color="Gray"/>
        </Border.Effect>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Кнопка закрытия -->
            <Button Content="✕" 
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="20"
                    Foreground="#7F8C8D"
                    Cursor="Hand"
                    Click="BtnClose_Click"
                    Margin="0,-10,-10,0"/>

            <!-- Заголовок -->
            <TextBlock Text="📝 Создание аккаунта" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Foreground="#2C3E50"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,20"/>

            <!-- Иконка -->
            <TextBlock Text="🔐" 
                       FontSize="48" 
                       HorizontalAlignment="Center"
                       Grid.Row="1"
                       Margin="0,0,0,20"/>

            <!-- Поле имени -->
            <StackPanel Grid.Row="2" Margin="0,0,0,15">
                <TextBlock Text="Имя пользователя" 
                           Foreground="#34495E" 
                           Margin="0,0,0,5"
                           FontSize="14"/>
                <TextBox x:Name="txtUsername" 
                         Height="40" 
                         FontSize="14"
                         Padding="10,0"
                         BorderBrush="#BDC3C7"
                         BorderThickness="1"
                         
                         Background="#F8F9F9"/>
            </StackPanel>

            <!-- Поле email -->
            <StackPanel Grid.Row="3" Margin="0,0,0,15">
                <TextBlock Text="Email" 
                           Foreground="#34495E" 
                           Margin="0,0,0,5"
                           FontSize="14"/>
                <TextBox x:Name="txtEmail" 
                         Height="40" 
                         FontSize="14"
                         Padding="10,0"
                         BorderBrush="#BDC3C7"
                         BorderThickness="1"
                         
                         Background="#F8F9F9"/>
            </StackPanel>

            <!-- Поле пароля -->
            <StackPanel Grid.Row="4" Margin="0,0,0,15">
                <TextBlock Text="Пароль" 
                           Foreground="#34495E" 
                           Margin="0,0,0,5"
                           FontSize="14"/>
                <PasswordBox x:Name="txtPassword" 
                             Height="40" 
                             FontSize="14"
                             Padding="10,0"
                             BorderBrush="#BDC3C7"
                             BorderThickness="1"
                             
                             Background="#F8F9F9"/>
            </StackPanel>

            <!-- Подтверждение пароля -->
            <StackPanel Grid.Row="5" Margin="0,0,0,25">
                <TextBlock Text="Подтверждение пароля" 
                           Foreground="#34495E" 
                           Margin="0,0,0,5"
                           FontSize="14"/>
                <PasswordBox x:Name="txtConfirmPassword" 
                             Height="40" 
                             FontSize="14"
                             Padding="10,0"
                             BorderBrush="#BDC3C7"
                             BorderThickness="1"
                             
                             Background="#F8F9F9"/>
            </StackPanel>

            <!-- Кнопка регистрации -->
            <Button Grid.Row="6" 
                    Content="Зарегистрироваться" 
                    Height="45"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="#2ECC71"
                    Foreground="White"
                    BorderThickness="0"
                    
                    Cursor="Hand"
                    Click="BtnRegister_Click"
                    Margin="0,0,0,15">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#2ECC71"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#27AE60"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#229954"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Ссылка на вход -->
            <TextBlock Grid.Row="6" 
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Center">
                <Run Text="Уже есть аккаунт?" 
                     Foreground="#7F8C8D"/>
                <Hyperlink Click="LoginLink_Click"
                          Foreground="#3498DB">
                    Войти
                </Hyperlink>
            </TextBlock>
        </Grid>
    </Border>
</Window>
