<Window x:Class="Manager_password.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Manager_password"
        mc:Ignorable="d"
        Title="Менеджер1 паролей" 
        Height="700" Width="1155"
        WindowStartupLocation="CenterScreen"
        Background="#F0F3F4">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Background="#2C3E50" Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="🔐 Менеджер паролей" 
                           Foreground="White" 
                           FontSize="20" 
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="➕ Добавить пароль" 
                            Background="#3498DB"
                            Foreground="White"
                            BorderThickness="0"
                            Padding="15,8"
                            Margin="0,0,10,0"
                            Cursor="Hand"
                            Click="AddPassword_Click"/>
                    <Button Content="🚪 Выйти" 
                            Background="#E74C3C"
                            Foreground="White"
                            BorderThickness="0"
                            Padding="15,8"
                            Cursor="Hand"
                            Click="Logout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основной контент -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель с категориями -->
            <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,10,0">
                <StackPanel>
                    <TextBlock Text="Категории" 
                               FontSize="16" 
                               FontWeight="Bold" 
                               Foreground="#2C3E50"
                               Margin="0,0,0,15"/>

                    <ListBox x:Name="CategoriesList" 
                             Background="Transparent"
                             BorderThickness="0"
                             SelectionMode="Single"
                             SelectionChanged="CategoriesList_SelectionChanged">
                        <!-- Пункты будут добавляться программно -->
                    </ListBox>
                </StackPanel>
            </Border>

            <!-- Правая панель с паролями -->
            <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Поиск -->
                    <TextBox x:Name="SearchBox" 
                             Height="35"
                             Padding="10,0"
                             Margin="0,0,0,15"
                             BorderBrush="#BDC3C7"
                             BorderThickness="1"
                             TextChanged="SearchBox_TextChanged">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Background" Value="#F8F9F9"/>
                                <Style.Triggers>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter Property="Background" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Список паролей -->
                    <ListView x:Name="PasswordsList" Grid.Row="1"
                              Background="Transparent"
                              BorderThickness="0"
                              MouseDoubleClick="ListView_MouseDoubleClick"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Название" Width="150" 
                                                DisplayMemberBinding="{Binding Title}"/>
                                <GridViewColumn Header="Логин" Width="150" 
                                                DisplayMemberBinding="{Binding Username}"/>
                                <GridViewColumn Header="Пароль" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="••••••••" Margin="0,0,5,0"/>
                                                <Button Content="👁" 
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        FontSize="12"
                                                        Cursor="Hand"
                                                        Click="ShowPassword_Click"
                                                        Tag="{Binding Id}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Сайт" Width="150" 
                                                DisplayMemberBinding="{Binding Website}"/>
                                <GridViewColumn Header="Категория" Width="120">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding CategoryName}" 
                                                       Foreground="{Binding CategoryColor}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Действия" Width="150">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="✏️" 
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Margin="0,0,5,0"
                                                        Cursor="Hand"
                                                        Click="EditPassword_Click"
                                                        Tag="{Binding Id}"/>
                                                <Button Content="📋" 
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Margin="0,0,5,0"
                                                        Cursor="Hand"
                                                        Click="CopyPassword_Click"
                                                        Tag="{Binding Id}"
                                                        ToolTip="Копировать пароль"/>
                                                <Button Content="👤" 
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Margin="0,0,5,0"
                                                        Cursor="Hand"
                                                        Click="CopyUsername_Click"
                                                        Tag="{Binding Id}"
                                                        ToolTip="Копировать логин"/>
                                                <Button Content="🗑️" 
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        Click="DeletePassword_Click"
                                                        Tag="{Binding Id}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- Нижняя статусная панель -->
        <Border Grid.Row="2" Background="#2C3E50" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Статус текст -->
                <TextBlock x:Name="StatusText" 
                           Foreground="#ECF0F1" 
                           Text="Готов к работе"
                           VerticalAlignment="Center"/>

                <!-- Информация о пользователе -->
                <TextBlock Grid.Column="1" 
                           x:Name="UserInfoText" 
                           Foreground="#ECF0F1" 
                           Text="Пользователь: "
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
