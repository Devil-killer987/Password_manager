<Window x:Class="Password_manager.AddPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Password_manager"
        mc:Ignorable="d"
         Title="Добавление пароля" 
        Height="650" Width="400"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown"
         KeyDown="Window_KeyDown">
    <Border CornerRadius="20" Background="White" Padding="25">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок и кнопка закрытия -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="WindowTitle" 
                           Text="➕ Добавить пароль" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="#2C3E50"
                           Margin="0,0,0,20"/>

                <Button Grid.Column="1" 
                        Content="✕" 
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="20"
                        Foreground="#7F8C8D"
                        Cursor="Hand"
                        Click="BtnClose_Click"
                        Margin="0,-10,-10,0"/>
            </Grid>

            <!-- Название -->
            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="Название *" 
                           Foreground="#34495E" 
                           Margin="0,0,0,5"
                           FontSize="14"/>
                <TextBox x:Name="txtTitle" 
                         Height="35" 
                         Padding="10,0"
                         BorderBrush="#BDC3C7"
                         BorderThickness="1"
                         KeyDown="TxtTitle_KeyDown"/>
            </StackPanel>

            <!-- Логин -->
            <StackPanel Grid.Row="2" Margin="0,0,0,15">
                <TextBlock Text="Логин *" 
                           Foreground="#34495E" 
                           Margin="0,0,0,5"
                           FontSize="14"/>
                <TextBox x:Name="txtUsername" 
                         Height="35" 
                         Padding="10,0"
                         BorderBrush="#BDC3C7"
                         BorderThickness="1"
                         KeyDown="TxtUsername_KeyDown"/>
            </StackPanel>

            <!-- Пароль с двумя кнопками генерации -->
            <StackPanel Grid.Row="3" Margin="0,0,0,15">
                <TextBlock Text="Пароль *" 
                           Foreground="#34495E" 
                           Margin="0,0,0,5"
                           FontSize="14"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <PasswordBox x:Name="txtPassword" 
                                 Height="35" 
                                 Padding="10,0"
                                 BorderBrush="#BDC3C7"
                                 BorderThickness="1"
                                 KeyDown="TxtPassword_KeyDown"/>

                    <Button Grid.Column="1" 
                            x:Name="btnGenerateSimple"
                            Content="🎲"
                            Width="35"
                            Height="35"
                            Background="#3498DB"
                            Foreground="White"
                            BorderThickness="0"
                            Margin="2,0,2,0"
                            Cursor="Hand"
                            Click="GenerateSimplePassword_Click"
                            ToolTip="Быстрая генерация (16 символов)"/>

                    <Button Grid.Column="2" 
                            x:Name="btnGenerateSettings"
                            Content="⚙️"
                            Width="35"
                            Height="35"
                            Background="#9B59B6"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="GenerateWithSettings_Click"
                            ToolTip="Расширенные настройки генерации"/>
                </Grid>
            </StackPanel>

            <!-- Сайт/Приложение -->
            <StackPanel Grid.Row="4" Margin="0,0,0,15">
                <TextBlock Text="Сайт / Приложение" 
                           Foreground="#34495E" 
                           Margin="0,0,0,5"
                           FontSize="14"/>
                <TextBox x:Name="txtWebsite" 
                         Height="35" 
                         Padding="10,0"
                         BorderBrush="#BDC3C7"
                         BorderThickness="1"
                         KeyDown="TxtWebsite_KeyDown"/>
            </StackPanel>

            <!-- Категория -->
            <StackPanel Grid.Row="5" Margin="0,0,0,15">
                <TextBlock Text="Категория" 
                           Foreground="#34495E" 
                           Margin="0,0,0,5"
                           FontSize="14"/>
                <ComboBox x:Name="cmbCategory" 
                          Height="35"
                          BorderBrush="#BDC3C7"
                          BorderThickness="1"
                          DisplayMemberPath="Name"
                          SelectedValuePath="Id"/>
            </StackPanel>

            <!-- Заметки -->
            <StackPanel Grid.Row="6" Margin="0,0,0,20">
                <TextBlock Text="Заметки" 
                           Foreground="#34495E" 
                           Margin="0,0,0,5"
                           FontSize="14"/>
                <TextBox x:Name="txtNotes" 
                         Height="60" 
                         Padding="10"
                         BorderBrush="#BDC3C7"
                         BorderThickness="1"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         />
            </StackPanel>

            <!-- Кнопки -->
            <StackPanel Grid.Row="7" 
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom">
                <Button Content="Отмена" 
                        Width="100"
                        Height="35"
                        Background="#95A5A6"
                        Foreground="White"
                        BorderThickness="0"
                        Margin="0,0,10,0"
                        Cursor="Hand"
                        Click="BtnCancel_Click"/>
                <Button x:Name="btnSave" 
                        Content="Сохранить" 
                        Width="100"
                        Height="35"
                        Background="#2ECC71"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnSave_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
