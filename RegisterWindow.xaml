<Window x:Class="Password_manager.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Password_manager"
        mc:Ignorable="d"
         Title="Менеджер паролей - Регистрация" 
        Height="650" Width="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown">

    <Border CornerRadius="20" Background="White" Padding="25">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок и кнопка закрытия -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="WindowTitle" 
                           Text="📝 Регистрация" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="#2C3E50"
                           Margin="0,0,0,20"/>

                <Button Grid.Column="1" 
                        Content="✕" 
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="20"
                        Foreground="#7F8C8D"
                        Cursor="Hand"
                        Click="BtnClose_Click"
                        Margin="0,-10,-10,0"/>
            </Grid>

            <!-- Имя пользователя -->
            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <TextBlock Text="Имя пользователя" 
                           Foreground="#34495E" 
                           Margin="0,0,0,5"
                           FontSize="14"/>
                <TextBox x:Name="txtUsername" 
                         Height="35" 
                         Padding="10,0"
                         BorderBrush="#BDC3C7"
                         BorderThickness="1"
                         KeyDown="TxtUsername_KeyDown"/>
            </StackPanel>

            <!-- Email -->
            <StackPanel Grid.Row="2" Margin="0,0,0,15">
                <TextBlock Text="Email" 
                           Foreground="#34495E" 
                           Margin="0,0,0,5"
                           FontSize="14"/>
                <TextBox x:Name="txtEmail" 
                         Height="35" 
                         Padding="10,0"
                         BorderBrush="#BDC3C7"
                         BorderThickness="1"
                         KeyDown="TxtEmail_KeyDown"/>
            </StackPanel>

            <!-- Пароль -->
            <StackPanel Grid.Row="3" Margin="0,0,0,15">
                <TextBlock Text="Пароль" 
                           Foreground="#34495E" 
                           Margin="0,0,0,5"
                           FontSize="14"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <PasswordBox x:Name="txtPassword" 
                                 Height="35" 
                                 Padding="10,0"
                                 BorderBrush="#BDC3C7"
                                 BorderThickness="1"
                                 PasswordChanged="TxtPassword_PasswordChanged"
                                 KeyDown="TxtPassword_KeyDown"/>

                    <Button Grid.Column="1" 
                            x:Name="btnGeneratePassword"
                            Content="🎲"
                            Width="35"
                            Height="35"
                            Background="#3498DB"
                            Foreground="White"
                            BorderThickness="0"
                            Margin="2,0,0,0"
                            Cursor="Hand"
                            Click="GeneratePassword_Click"
                            ToolTip="Сгенерировать пароль"/>
                </Grid>
            </StackPanel>

            <!-- Индикатор сложности пароля -->
            <StackPanel Grid.Row="4" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ProgressBar x:Name="PasswordStrengthBar" 
                                 Height="5" 
                                 Minimum="0" 
                                 Maximum="100"
                                 Foreground="#4CAF50"
                                 Background="#EEEEEE"
                                 Grid.ColumnSpan="2"/>

                    <TextBlock x:Name="PasswordStrengthText" 
                               Grid.Column="1"
                               FontSize="10"
                               Margin="5,0,0,0"
                               VerticalAlignment="Center"/>
                </Grid>
            </StackPanel>

            <!-- !!! ДОБАВЛЕНО: Подтверждение пароля !!! -->
            <StackPanel Grid.Row="5" Margin="0,0,0,20">
                <TextBlock Text="Подтверждение пароля" 
                           Foreground="#34495E" 
                           Margin="0,0,0,5"
                           FontSize="14"/>
                <PasswordBox x:Name="txtConfirmPassword" 
                             Height="35" 
                             Padding="10,0"
                             BorderBrush="#BDC3C7"
                             BorderThickness="1"
                             PasswordChanged="TxtConfirmPassword_PasswordChanged"
                             KeyDown="TxtConfirmPassword_KeyDown"/>

                <!-- Индикатор совпадения паролей -->
                <TextBlock x:Name="PasswordMatchText" 
                           FontSize="11"
                           Margin="0,3,0,0"
                           HorizontalAlignment="Right"/>
            </StackPanel>

            <!-- Кнопка регистрации -->
            <Button Grid.Row="6" 
                    x:Name="btnRegister"
                    Content="Зарегистрироваться" 
                    Height="40"
                    Background="#2ECC71"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="14"
                    FontWeight="Bold"
                    Cursor="Hand"
                    Click="BtnRegister_Click"
                    IsDefault="True"/>

            <!-- Ссылка на вход -->
            <StackPanel Grid.Row="7" 
                        Margin="0,15,0,0"
                        HorizontalAlignment="Center">
                <TextBlock Text="Уже есть аккаунт?" 
                           Foreground="#7F8C8D" 
                           FontSize="12"
                           HorizontalAlignment="Center"/>
                <Button Content="Войти" 
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#3498DB"
                        FontSize="12"
                        FontWeight="Bold"
                        Cursor="Hand"
                        Click="LoginLink_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#2980B9"/>
                                    <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
