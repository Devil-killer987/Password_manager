<Window x:Class="Password_manager.PasswordGeneratorSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Password_manager"
        mc:Ignorable="d"
        Title="Настройки генерации пароля" Height="700" Width="450"
         WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseDown="Window_MouseDown"
        KeyDown="Window_KeyDown">
    <Border CornerRadius="20" Background="White" Padding="25">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="⚙️ Настройки генерации пароля" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="#2C3E50"
                           Margin="0,0,0,20"/>

                <Button Grid.Column="1" 
                        Content="✕" 
                        Background="Transparent"
                        BorderThickness="0"
                        FontSize="18"
                        Foreground="#7F8C8D"
                        Cursor="Hand"
                        Click="BtnClose_Click"
                        Margin="0,-5,-5,0"/>
            </Grid>

            <!-- Длина пароля -->
            <StackPanel Grid.Row="1" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Длина пароля:" 
                               Foreground="#34495E" 
                               FontSize="14"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" 
                               x:Name="txtLengthValue" 
                               Text="16" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               Foreground="#3498DB"
                               Margin="0,0,10,0"/>
                </Grid>
                <Slider x:Name="sldLength" 
                        Minimum="4" 
                        Maximum="32" 
                        Value="16" 
                        TickFrequency="1"
                        TickPlacement="BottomRight"
                        IsSnapToTickEnabled="True"
                        ValueChanged="sldLength_ValueChanged"
                        Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Типы символов -->
            <GroupBox Grid.Row="2" Header="Включать символы:" Margin="0,0,0,15"
                      Foreground="#34495E" FontSize="14">
                <StackPanel Margin="10">
                    <CheckBox x:Name="chkUppercase" 
                              Content="Заглавные буквы (A-Z)" 
                              IsChecked="True"
                              Margin="0,5"
                              Checked="UpdatePreview"
                              Unchecked="UpdatePreview"/>
                    <CheckBox x:Name="chkLowercase" 
                              Content="Строчные буквы (a-z)" 
                              IsChecked="True"
                              Margin="0,5"
                              Checked="UpdatePreview"
                              Unchecked="UpdatePreview"/>
                    <CheckBox x:Name="chkDigits" 
                              Content="Цифры (0-9)" 
                              IsChecked="True"
                              Margin="0,5"
                              Checked="UpdatePreview"
                              Unchecked="UpdatePreview"/>
                    <CheckBox x:Name="chkSpecial" 
                              Content="Спецсимволы (!-+)" 
                              IsChecked="True"
                              Margin="0,5"
                              Checked="UpdatePreview"
                              Unchecked="UpdatePreview"/>
                </StackPanel>
            </GroupBox>

            <!-- Исключить похожие символы -->
            <GroupBox Grid.Row="3" Header="Дополнительные настройки:" Margin="0,0,0,15"
                      Foreground="#34495E" FontSize="14">
                <StackPanel Margin="10">
                    <CheckBox x:Name="chkExcludeSimilar" 
                              Content="Исключить похожие символы (i, l, 1, L, o, 0, O)" 
                              Margin="0,5"
                              Checked="UpdatePreview"
                              Unchecked="UpdatePreview"/>
                    <CheckBox x:Name="chkExcludeAmbiguous" 
                              Content="Исключить неоднозначные символы ({}, [], (), \/, \\)" 
                              Margin="0,5"
                              Checked="UpdatePreview"
                              Unchecked="UpdatePreview"/>
                    <CheckBox x:Name="chkNoConsecutive" 
                              Content="Без повторяющихся символов" 
                              Margin="0,5"
                              Checked="UpdatePreview"
                              Unchecked="UpdatePreview"/>
                </StackPanel>
            </GroupBox>

            <!-- Предпросмотр пароля -->
            <GroupBox Grid.Row="4" Header="Предпросмотр:" Margin="0,0,0,15"
                      Foreground="#34495E" FontSize="14">
                <StackPanel Margin="10">
                    <TextBox x:Name="txtPreview" 
                             FontFamily="Consolas"
                             FontSize="14"
                             Padding="8"
                             IsReadOnly="True"
                             Background="#F8F9F9"
                             BorderBrush="#BDC3C7"
                             TextWrapping="Wrap"/>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="txtStrength" 
                                   Text="Сложность: Отличный"
                                   Foreground="#2ECC71"
                                   FontSize="12"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" 
                                   x:Name="txtEntropy" 
                                   Text="Энтропия: 95 бит"
                                   FontSize="12"
                                   Foreground="#7F8C8D"/>
                    </Grid>
                </StackPanel>
            </GroupBox>

            <!-- Индикатор сложности -->
            <ProgressBar x:Name="StrengthBar" 
                         Grid.Row="5"
                         Height="8"
                         Minimum="0" 
                         Maximum="100"
                         Value="85"
                         Foreground="#2ECC71"
                         Background="#EEEEEE"
                         Margin="0,0,0,15"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="6" 
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,20,0,0">
                <Button Content="Сгенерировать" 
                        Width="120"
                        Height="35"
                        Background="#3498DB"
                        Foreground="White"
                        BorderThickness="0"
                        Margin="0,0,10,0"
                        Cursor="Hand"
                        Click="GenerateNewPreview_Click"/>
                <Button Content="Применить" 
                        Width="100"
                        Height="35"
                        Background="#2ECC71"
                        Foreground="White"
                        BorderThickness="0"
                        Margin="0,0,10,0"
                        Cursor="Hand"
                        Click="ApplySettings_Click"/>
                <Button Content="Отмена" 
                        Width="100"
                        Height="35"
                        Background="#95A5A6"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnCancel_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
